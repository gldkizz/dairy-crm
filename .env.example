# Public URL of the site (no trailing slash). Use server IP if you have no domain.
# Example: APP_URL=http://203.0.113.10
APP_URL=http://localhost

# Change this in production
AUTH_SECRET=dairy-crm-dev-secret-change-in-production

# Host nginx: copy nginx/dairy-crm.conf to /etc/nginx/sites-available/
# and enable it (see comments in that file). App listens on 127.0.0.1:3000.
