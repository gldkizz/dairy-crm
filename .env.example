# Public URL of the site (no trailing slash).
# With host nginx on port 8080 (existing site keeps :80):
#   APP_URL=http://203.0.113.10:8080
APP_URL=http://localhost:8080

# Change this in production
AUTH_SECRET=dairy-crm-dev-secret-change-in-production

# Host nginx: copy nginx/dairy-crm.conf → sites-available, enable, reload.
# CRM listens on host :8080 → proxies to Docker app on 127.0.0.1:3000.
